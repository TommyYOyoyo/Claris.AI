   "source": [
    "# Used to reset models to their very first state\n",
    "\n",
    "import os\n",
    "import glob\n",
    "\n",
    "files = glob.glob(\"./claris*.pth\")\n",
    "\n",
    "for f in files: \n",
    "    try:\n",
    "        os.remove(f)\n",
    "        print(f\"Removed {f}\")\n",
    "    except OSError as e:\n",
    "        print(f\"Error while deleting {f} : returned {e.strerror}\")\n"
   ]
  }
